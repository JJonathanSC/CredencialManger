<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="26dp">

        <!-- TITULO -->
        <TextView
            android:id="@+id/tvTituloGenerarPass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generador de contraseñas"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#12343B"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crea contraseñas seguras"
            android:textColor="#6B8790"
            android:layout_marginBottom="20dp"/>

        <!-- LONGITUD -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Longitud (ej: 12)"
            app:boxBackgroundColor="#F4FBFC"
            app:boxStrokeWidth="0dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtLongitudGenerarPass"
                android:inputType="number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- BOTON GENERAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerarPass"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Generar contraseña"
            android:layout_marginTop="20dp"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#1F7A8C"
            android:textColor="@android:color/white"
            app:cornerRadius="16dp"/>

        <!-- RESULTADO -->
        <TextView
            android:id="@+id/tvGeneratedPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aquí aparecerá la contraseña"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#12343B"
            android:layout_marginTop="24dp"/>

        <!-- BOTON COPIAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCopiarGenerarPass"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Copiar contraseña"
            android:layout_marginTop="16dp"
            android:textAllCaps="false"
            android:backgroundTint="#6B8790"
            android:textColor="@android:color/white"
            app:cornerRadius="16dp"/>

    </LinearLayout>

</ScrollView>