<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- ESPACIO -->
            <Space
                android:layout_width="wrap_content"
                android:layout_height="40dp"/>

            <!-- LOGO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="90dp"
                android:layout_height="90dp"
                app:cardCornerRadius="45dp"
                app:cardBackgroundColor="#F4FBFC"
                app:strokeColor="#CDE7EA"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp"
                    android:src="@drawable/ic_user"
                    app:tint="#1F7A8C"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- TITULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear cuenta"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#12343B"
                android:layout_marginTop="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Regístrate para continuar"
                android:textColor="#6B8790"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="30dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#D7ECEF"
                app:strokeWidth="1dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- NOMBRE -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre completo"
                        app:boxBackgroundColor="#F4FBFC"
                        app:boxStrokeWidth="0dp"
                        app:startIconDrawable="@drawable/ic_user"
                        app:startIconTint="#4E7B83">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtNombreRegistro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#12343B"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- EMAIL -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Correo electrónico"
                        app:boxBackgroundColor="#F4FBFC"
                        app:boxStrokeWidth="0dp"
                        app:startIconDrawable="@drawable/ic_visibility"
                        app:startIconTint="#4E7B83">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEmailRegistro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="#12343B"/>
                    </com.google.android.material.textfield.TextInputLayout>


                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Número de teléfono (+503...)"
                        app:boxBackgroundColor="#F4FBFC"
                        app:boxStrokeWidth="0dp"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="#4E7B83">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtTelefonoRegistro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textColor="#12343B"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PASSWORD -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Contraseña"
                        app:boxBackgroundColor="#F4FBFC"
                        app:boxStrokeWidth="0dp"
                        app:endIconMode="password_toggle"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="#4E7B83">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtPasswordRegistro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="#12343B"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Llave maestra"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtMasterPassRegistro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- BOTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCrearCuentaRegistro"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="Crear cuenta"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#1F7A8C"
                        app:cornerRadius="18dp"/>

                    <!-- VOLVER -->
                    <TextView
                        android:id="@+id/tvVolverFromRegistro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="18dp"
                        android:text="Volver al login"
                        android:textColor="#1F7A8C"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>